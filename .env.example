# ============================================================
# SUPABASE — https://supabase.com/dashboard → Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Python side (data collectors + MCP server writing to Supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ============================================================
# KOTAK NEO API v2 — Get from https://kotaksecurities.com/platform/kotak-neo-trade-api/
# ============================================================
KOTAK_CONSUMER_KEY=your_consumer_key_here
KOTAK_CONSUMER_SECRET=your_consumer_secret_here
KOTAK_MOBILE_NUMBER=9999999999
KOTAK_UCC=ABCXYZ
KOTAK_MPIN=123456
KOTAK_TOTP_SECRET=BASE32_TOTP_SECRET_FROM_QR_SCAN
KOTAK_ENVIRONMENT=prod

# ============================================================
# SOCIAL SENTIMENT — NO API KEY NEEDED
# Uses StockTwits (free) + Google News RSS + Economic Times RSS
# ============================================================

# ============================================================
# FINNHUB — https://finnhub.io/ (free tier available)
# ============================================================
FINNHUB_API_KEY=your_finnhub_api_key

# ============================================================
# ALPHA VANTAGE — https://www.alphavantage.co/ (optional fallback)
# ============================================================
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ============================================================
# TELEGRAM BOT — for trade alerts and EOD summary
# Create bot via @BotFather on Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================================
# FREE LLM ANALYSIS — used as an 8th vote in the consensus engine
# Groq (primary):     https://console.groq.com     — free, 14,400 req/day
# Cerebras (fallback): https://cloud.cerebras.ai   — free, 14,400 req/day
# At least one key is needed; both can be set for automatic failover.
# ============================================================
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ============================================================
# REDIS — for caching (optional, falls back to in-memory)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# STRATEGY SETTINGS
# ============================================================
STRATEGY_MODE=intraday
MAX_POSITIONS=5
MAX_ACCOUNT_RISK_PCT=0.02
MAX_SINGLE_STOCK_PCT=0.05
MAX_PENNY_STOCK_PCT=0.01
MAX_FNO_PCT=0.02
CIRCUIT_DAILY_LOSS_PCT=0.03
CIRCUIT_CONSECUTIVE_LOSSES=5
CIRCUIT_MAX_DRAWDOWN_PCT=0.15
MIN_SIGNAL_CONFIDENCE=0.65
MIN_FNO_CONFIDENCE=0.70

